{
    "extends": "./tsconfig.base.json",
    "compilerOptions": {
        "baseUrl": ".",
        "paths": {
            "@repo/ui": [
                "src/packages/ui/src"
            ],
            "@repo/ui/*": [
                "src/packages/ui/src/*"
            ]
        }
    },
    "include": [
        "src/**/*.ts",
        "src/**/*.tsx",
        "tests/**/*.ts",
        "tests/**/*.tsx",
        "examples/**/*.ts",
        "examples/**/*.tsx"
    ]
}